<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- 顶部工具栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/white"
            app:title="@string/app_name" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== 大盘指数头部区域（深色背景） ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingBottom="12dp">

                <!-- 上证指数（主卡片） -->
                <LinearLayout
                    android:id="@+id/card_sh_index"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_transparent"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tv_sh_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="上证指数"
                        android:textColor="#B0FFFFFF"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/tv_sh_point"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tv_sh_change"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFAB91"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_sh_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFAB91"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tv_sh_volume"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="成交额: --"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_sh_range"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="振幅: --"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 深证 + 创业板 双列卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 深证成指 -->
                    <LinearLayout
                        android:id="@+id/card_sz_index"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/card_transparent"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/tv_sz_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="深证成指"
                            android:textColor="#B0FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_sz_point"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:id="@+id/tv_sz_change"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="#FFFFAB91"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_sz_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFAB91"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_sz_volume"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="成交额: --"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 创业板指 -->
                    <LinearLayout
                        android:id="@+id/card_cy_index"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/card_transparent"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/tv_cy_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="创业板指"
                            android:textColor="#B0FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_cy_point"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:id="@+id/tv_cy_change"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="#FFFFAB91"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_cy_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFAB91"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_cy_volume"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="成交额: --"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- ===== 下方内容区域（浅色背景） ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <!-- 服务控制 + 状态栏（一行） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/btn_start_service"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="开始监控"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:background="@drawable/btn_primary"
                        android:paddingHorizontal="14dp"
                        android:layout_marginEnd="8dp"
                        android:stateListAnimator="@null" />

                    <Button
                        android:id="@+id/btn_sync_history"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="更新数据"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:background="@drawable/btn_outline"
                        android:paddingHorizontal="10dp"
                        android:layout_marginEnd="8dp"
                        android:stateListAnimator="@null" />

                    <View
                        android:id="@+id/status_indicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="#9E9E9E"
                        android:layout_marginEnd="4dp"
                        android:layout_gravity="top"
                        android:layout_marginTop="5dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="服务未启动"
                            android:textColor="#666666"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_last_update"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text=""
                            android:textColor="#999999"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- AI分析卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_elevated"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🤖 AI 策略分析"
                            android:textColor="#1A237E"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_analysis_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#999999"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- 三指标行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <!-- 情绪 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="市场情绪"
                                android:textColor="#999999"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tv_sentiment"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="#E0E0E0" />

                        <!-- 趋势 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="趋势方向"
                                android:textColor="#999999"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tv_trend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="#E0E0E0" />

                        <!-- 风险 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="风险等级"
                                android:textColor="#999999"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tv_risk"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="8dp" />

                    <!-- 操作建议 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="操作建议"
                        android:textColor="#999999"
                        android:textSize="10sp"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_suggestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="等待AI分析..."
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.2"
                        android:layout_marginBottom="4dp" />

                    <!-- 详细分析（可展开） -->
                    <TextView
                        android:id="@+id/tv_toggle_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="查看详细分析 ▼"
                        android:textColor="#1A73E8"
                        android:textSize="11sp"
                        android:paddingVertical="4dp" />

                    <TextView
                        android:id="@+id/tv_analysis_detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#555555"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.2"
                        android:visibility="gone"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- ===== 策略推荐 2x2 网格 ===== -->

                <!-- 第一行：市场要闻 + 板块推荐 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <!-- 市场要闻 -->
                    <LinearLayout
                        android:id="@+id/card_news"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/card_news_bg"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginEnd="5dp"
                        android:minHeight="160dp">

                        <!-- 标题行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/circle_icon_bg_light"
                                android:text="📰"
                                android:textSize="11sp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="市场要闻"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginStart="6dp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_news_more"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="查看全部 ▶"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- 新闻列表容器 -->
                        <LinearLayout
                            android:id="@+id/layout_news_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- 无数据时的占位 -->
                        <TextView
                            android:id="@+id/tv_news_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="暂无新闻数据"
                            android:textColor="#B0FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- 板块推荐 -->
                    <LinearLayout
                        android:id="@+id/card_sector"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/card_sector_bg"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginStart="5dp"
                        android:minHeight="160dp">

                        <!-- 标题行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/circle_icon_bg"
                                android:text="🔥"
                                android:textSize="11sp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="板块推荐"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginStart="6dp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_sector_more"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="查看全部 ▶"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- 推荐列表容器 -->
                        <LinearLayout
                            android:id="@+id/layout_sector_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- 无数据时的占位 -->
                        <TextView
                            android:id="@+id/tv_sector_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="等待AI分析..."
                            android:textColor="#B0FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 第二行：竞价推荐 + 尾盘推荐 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- 开盘竞价推荐 -->
                    <LinearLayout
                        android:id="@+id/card_auction"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/card_auction_bg"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginEnd="5dp"
                        android:minHeight="160dp">

                        <!-- 标题行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/circle_icon_bg"
                                android:text="⚡"
                                android:textSize="11sp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="竞价推荐"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginStart="6dp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_auction_more"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="查看全部 ▶"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- 推荐列表容器 -->
                        <LinearLayout
                            android:id="@+id/layout_auction_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- 无数据时的占位 -->
                        <TextView
                            android:id="@+id/tv_auction_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="等待AI分析..."
                            android:textColor="#B0FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- 尾盘推荐 -->
                    <LinearLayout
                        android:id="@+id/card_closing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/card_closing_bg"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginStart="5dp"
                        android:minHeight="160dp">

                        <!-- 标题行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/circle_icon_bg"
                                android:text="🌙"
                                android:textSize="11sp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="尾盘推荐"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginStart="6dp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tv_closing_more"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="查看全部 ▶"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <!-- 推荐列表容器 -->
                        <LinearLayout
                            android:id="@+id/layout_closing_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- 无数据时的占位 -->
                        <TextView
                            android:id="@+id/tv_closing_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="等待AI分析..."
                            android:textColor="#B0FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 底部免责声明 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠ 免责声明：以上推荐均由AI生成，仅供参考，不构成投资建议。投资有风险，入市需谨慎。"
                    android:textColor="#999999"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4"
                    android:gravity="center"
                    android:paddingVertical="16dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
